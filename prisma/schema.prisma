generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── AUTHENTIFICATION ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  websites Website[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

// ─── SITES WORDPRESS ──────────────────────────────────────────────────────────

model Website {
  id                String        @id @default(cuid())
  userId            String
  name              String
  url               String
  wpUsername        String
  wpAppPassword     String
  customEndpointKey String
  status            WebsiteStatus @default(PENDING)
  lastTestedAt      DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile  Profile?
  articles ArticleLog[]
}

enum WebsiteStatus {
  PENDING
  ACTIVE
  ERROR
  PAUSED
}

// ─── PROFILS DE PUBLICATION ───────────────────────────────────────────────────

model Profile {
  id                 String   @id @default(cuid())
  websiteId          String   @unique
  language           String   @default("fr")
  topics             String[]
  tone               String   @default("informatif")
  articlesPerDay     Int      @default(1)
  autoMode           Boolean  @default(false)
  customPrompt       String?  @db.Text
  newsApiQuery       String?
  maxArticleAgeHours Int      @default(72)
  defaultCategoryIds Int[]    @default([])
  autoImage          Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

// ─── HISTORIQUE DES PUBLICATIONS ──────────────────────────────────────────────

model ArticleLog {
  id            String        @id @default(cuid())
  websiteId     String
  title         String
  wpPostId      Int?
  wpPostUrl     String?
  status        ArticleStatus
  mode          PublishMode
  inputTokens   Int           @default(0)
  outputTokens  Int           @default(0)
  estimatedCost Float         @default(0)
  errorMessage  String?       @db.Text
  sourceUrl     String?
  sourceName    String?
  imageUrl      String?
  categoryIds   Int[]         @default([])
  tags          String[]      @default([])
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model WhatsAppRequest {
  id           String   @id @default(cuid())
  senderJid    String
  instanceId   String
  websiteId    String
  totalCount   Int
  successCount Int      @default(0)
  failedCount  Int      @default(0)
  articleLinks String[] @default([])
  status       String   @default("PENDING") // PENDING, COMPLETED, FAILED
  createdAt    DateTime @default(now())
}

enum ArticleStatus {
  SUCCESS
  FAILED
  PENDING
}

enum PublishMode {
  AUTO
  MANUAL
}
