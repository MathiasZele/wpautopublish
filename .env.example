# Database (Neon / Railway / Supabase PostgreSQL)
# Pooled connection (runtime) — ajouter ?pgbouncer=true&connect_timeout=10 si pooler externe
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connect_timeout=10"
# Direct connection (migrations / prisma db push) — sans pooler
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js — generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="changeme_random_base64"
NEXTAUTH_URL="http://localhost:3000"
# Recommandé en prod derrière un proxy (Railway, Vercel, etc.)
AUTH_TRUST_HOST="true"

# URL publique de l'app (utilisée pour configurer le webhook Evolution)
# En prod sur Railway, RAILWAY_PUBLIC_DOMAIN est auto-injecté en fallback
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Evolution API (WhatsApp via Baileys)
EVOLUTION_API_URL="https://your-evolution-api-url"
EVOLUTION_API_KEY="your-evolution-api-key"
# Nom de l'instance Evolution dédiée à cette app (utilisé par /api/whatsapp/*)
WHATSAPP_INSTANCE_NAME="WPAutoPublish"
# Secret pour authentifier les webhooks entrants depuis Evolution (Global Webhook Token)
EVOLUTION_WEBHOOK_SECRET="your_secure_webhook_secret_here"

# OpenAI
OPENAI_API_KEY="sk-..."

# News providers — au moins un doit être configuré
# NewsAPI.org (gratuit pour dev)
NEWS_API_KEY="..."
# GNews (optionnel — provider news additionnel)
GNEWS_API_KEY=""
# Mediastack (optionnel — HTTPS uniquement, free tier en HTTP non supporté ici)
MEDIASTACK_API_KEY=""
# The Guardian (optionnel — fournit le bodyText complet pour grounder l'IA)
GUARDIAN_API_KEY=""

# Cloudinary — depuis Dashboard → Account Details
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# Redis (use rediss:// for TLS providers like Upstash)
REDIS_URL="redis://localhost:6379"

# Cron — generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRON_SECRET="changeme_random_base64"

# Encryption — 64 hex chars (32 bytes) for AES-256-GCM. NEVER CHANGE after sites are created.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="64_hex_chars_here"

# Cloudflare bypass — token partagé envoyé en header X-WP-Autopublish-Token sur
# toutes les requêtes vers WordPress. Configurer côté Cloudflare une WAF custom
# rule "Skip" qui matche ce header pour les sites en "Under Attack Mode" / "Bot
# Fight Mode". Sans cette variable, le header n'est pas envoyé (pas de fuite).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WP_CLOUDFLARE_BYPASS_TOKEN=""
